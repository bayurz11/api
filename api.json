{
    "openapi": "3.1.0",
    "info": {
        "title": "RESTO POS API Docs",
        "version": "v1",
        "description": "RESTO POS API documentation for local development and endpoint testing.\n\nAvailable starter flows:\n\n- Health check\n- Authentication with Sanctum bearer token\n- Dashboard summary\n\nUse the `POST /api/v1/auth/login` endpoint first, then send the returned bearer token for protected routes."
    },
    "servers": [
        {
            "url": "http://localhost/api/v1",
            "description": "Local API"
        }
    ],
    "security": [
        {
            "http": []
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "operationId": "auth.login",
                "summary": "Authenticate the user and return a Sanctum token",
                "tags": [
                    "Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "username",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "user": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer"
                                                },
                                                "name": {
                                                    "type": "string"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "roles": {
                                                    "type": "array",
                                                    "items": {}
                                                },
                                                "permissions": {
                                                    "type": "array",
                                                    "items": {}
                                                }
                                            },
                                            "required": [
                                                "id",
                                                "name",
                                                "username",
                                                "email",
                                                "roles",
                                                "permissions"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "token",
                                        "user"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                },
                "security": []
            }
        },
        "/auth/logout": {
            "post": {
                "operationId": "auth.logout",
                "summary": "Revoke the current access token",
                "tags": [
                    "Auth"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "const": "Logout berhasil."
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/auth/me": {
            "get": {
                "operationId": "auth.me",
                "summary": "Return the current authenticated user",
                "tags": [
                    "Auth"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "user": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "integer"
                                                },
                                                "name": {
                                                    "type": "string"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "roles": {
                                                    "type": "array",
                                                    "items": {}
                                                },
                                                "permissions": {
                                                    "type": "array",
                                                    "items": {}
                                                }
                                            },
                                            "required": [
                                                "id",
                                                "name",
                                                "username",
                                                "email",
                                                "roles",
                                                "permissions"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "user"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/dashboard": {
            "get": {
                "operationId": "v1.dashboard",
                "summary": "Return lightweight dashboard data for the mobile app",
                "tags": [
                    "Dashboard"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "summary": {
                                            "type": "object",
                                            "properties": {
                                                "total_tables": {
                                                    "type": "integer",
                                                    "minimum": 0
                                                },
                                                "available_tables": {
                                                    "type": "integer",
                                                    "minimum": 0
                                                },
                                                "open_bills": {
                                                    "type": "integer",
                                                    "minimum": 0
                                                },
                                                "today_sales": {
                                                    "type": "number"
                                                }
                                            },
                                            "required": [
                                                "total_tables",
                                                "available_tables",
                                                "open_bills",
                                                "today_sales"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "summary"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/health": {
            "get": {
                "operationId": "v1.health",
                "summary": "Handle the incoming request",
                "tags": [
                    "Health"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "const": "ok"
                                        },
                                        "service": {
                                            "type": "string",
                                            "const": "restopos-api"
                                        },
                                        "version": {
                                            "type": "string",
                                            "const": "v1"
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "service",
                                        "version"
                                    ]
                                }
                            }
                        }
                    }
                },
                "security": []
            }
        }
    },
    "components": {
        "securitySchemes": {
            "http": {
                "type": "http",
                "scheme": "bearer"
            }
        },
        "responses": {
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            },
            "AuthenticationException": {
                "description": "Unauthenticated",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            }
        }
    }
}